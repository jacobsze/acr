# ── Flask ──────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
DATABASE_PATH=./acr.db

# ── App Owner ────────────────────────────────────────────────────────
# This email gets owner-level access automatically on first run.
OWNER_EMAIL=you@example.com

# ── Email / SMTP (for sending OTP codes) ─────────────────────────────
# Use Gmail with an App Password (2FA must be enabled on the account).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourapp@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM_NAME=Cat Rescue Scheduler

# ── Claude API (for interpreting schedule emails) ─────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Gmail API (for monitoring the Google Group inbox) ─────────────────
# Download credentials.json from Google Cloud Console (OAuth 2.0 Desktop app).
# The token.json file is created automatically on first run.
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json
# The Google Group address whose messages you want to monitor.
GMAIL_MONITOR_EMAIL=acrpetco86@googlegroups.com
# How often to check for new emails (minutes).
GMAIL_CHECK_INTERVAL_MINUTES=5
