# ── Flask ──────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
# Leave DATABASE_URL blank to use SQLite locally.
# Render sets this automatically when you attach a Postgres database.
DATABASE_URL=

# ── App Owner ────────────────────────────────────────────────────────
OWNER_EMAIL=you@example.com
# Set this to your Render app URL so Clerk can verify sessions correctly.
APP_URL=https://your-app.onrender.com

# ── Clerk (https://dashboard.clerk.com) ──────────────────────────────
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Found in Clerk dashboard under "API Keys" → "Frontend API"
CLERK_FRONTEND_API_URL=https://prepared-dove-17.clerk.accounts.dev

# ── Claude API (for interpreting schedule emails) ─────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Gmail API (for monitoring the Google Group inbox) ─────────────────
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json
GMAIL_MONITOR_EMAIL=acrpetco86@googlegroups.com
GMAIL_CHECK_INTERVAL_MINUTES=5
